#> hsj.iris:setup/scoreboard
#
# Sets up the scoreboard (objectives and scores) for Iris
#
# @within hsj.iris:setup/load

scoreboard objectives add hsj.iris dummy {"text": "CNK Iris", "color": "gold"}
scoreboard objectives add hsj.iris.id dummy {"text": "CNK Iris entity IDs", "color": "gold"}

scoreboard players set $-1 hsj.iris -1
scoreboard players set $2 hsj.iris 2
scoreboard players set $11 hsj.iris 11
scoreboard players set $16 hsj.iris 16
scoreboard players set $256 hsj.iris 256
scoreboard players set $1000 hsj.iris 1000
scoreboard players set $33333 hsj.iris 33333
scoreboard players set $65536 hsj.iris 65536
scoreboard players set $1000000 hsj.iris 1000000
scoreboard players set $3129871 hsj.iris 3129871
scoreboard players set $42317861 hsj.iris 42317861
scoreboard players set $116129781 hsj.iris 116129781
